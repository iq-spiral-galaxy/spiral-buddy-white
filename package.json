{
  "name": "spiral-buddy-white",
  "version": "0.1.2",
  "description": "Spiral learning companion for the study of mind & consciousness (Psyche) — \"Explain it, don't explain it away.\" Local desktop app bridging Claude and Obsidian: roadmap-driven sessions, mechanism→gap→experience notes, spiral revisit detection.",
  "type": "module",
  "main": "electron/main.cjs",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "start": "tsx src/server.ts",
    "mcp": "tsx src/mcp.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "electron:dev": "tsc && electron electron/main.cjs",
    "electron:build": "tsc && electron-builder",
    "electron:build:mac": "tsc && electron-builder --mac",
    "electron:build:win": "tsc && electron-builder --win",
    "electron:build:linux": "tsc && electron-builder --linux"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.6.14",
    "open": "^10.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.10.2",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "claude",
    "anthropic",
    "obsidian",
    "spiral-learning",
    "learning",
    "agent",
    "psyche",
    "consciousness",
    "philosophy-of-mind"
  ],
  "author": "iq",
  "license": "MIT",
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "electron"
    ]
  }
}
