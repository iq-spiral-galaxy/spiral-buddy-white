# --- Required ---
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- Roadmap (Phase 1.5: dynamic roadmap selection) ---
# 로드맵들이 들어있는 root 디렉토리. 그 아래 모든 학습 로드맵을 자동 탐지한다.
# 로드맵 = README.md를 제외한 .md 파일이 2개 이상 직접 들어있는 디렉토리.
# 예: iq-dev-lab 전체를 root로 두면 안의 모든 deep-dive 시리즈가 자동으로 잡힘.
SPIRAL_ROADMAP_ROOT=

# (legacy / 선택) 단일 로드맵 디렉토리만 강제로 쓰고 싶을 때.
# 설정되면 그 부모가 root로, 자기는 pinned 로드맵으로 동작 (다른 로드맵은 안 보임).
# 동적 로드맵 선택을 쓰려면 비워두고 SPIRAL_ROADMAP_ROOT만 설정.
# SPIRAL_ROADMAP_PATH=

# --- Vault ---
SPIRAL_VAULT_PATH=
# (선택) 옵시디언에 등록된 vault 이름. 비워두면 자동 탐지된 .obsidian/ 디렉토리의 부모 이름 사용.
# 옵시디언 좌상단 vault 이름이 폴더명과 다르면 여기 명시.
SPIRAL_VAULT_NAME=

# --- Curated roadmaps (Phase 2) ---
# GitHub 조직의 public 레포를 자동으로 학습 로드맵으로 노출 ("Curated" 소스).
# 다른 사람도 spiral-buddy만 클론하면 이 조직의 학습 자료로 즉시 학습 가능.
# 기본값: iq-dev-lab. 다른 조직 사용 시 여기 지정.
# SPIRAL_CURATED_ORG=iq-dev-lab

# Curated 소스를 완전히 끄려면 1로 설정 (Local 로드맵만 사용)
# SPIRAL_DISABLE_CURATED=

# GitHub API 호출 시 인증 (선택). unauth는 60 req/hr 제한.
# 토큰 있으면 5000 req/hr. 안 써도 public repo 클론은 동작함.
# SPIRAL_GITHUB_TOKEN=

# --- Model ---
SPIRAL_MODEL=claude-sonnet-4-6
SPIRAL_MAX_TOKENS=4096

# --- Server ---
# Web app port (default 3737)
PORT=3737
# Set to "1" to NOT auto-open browser on startup
NO_OPEN=
